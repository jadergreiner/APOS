{
  "name": "apos-jira-plugin",
  "version": "0.3.0-beta",
  "description": "APOS Plugin for Jira - Detect orphaned features and link tasks to OKRs",
  "main": "src/index.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ --ext .js,.jsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "@atlaskit/jira-ui-kit": "^2.0.0",
    "@atlaskit/button": "^16.3.0",
    "@atlaskit/modal-dialog": "^12.5.0",
    "@atlaskit/dropdown-menu": "^10.8.0",
    "@atlaskit/spinner": "^16.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-react": "^7.22.0",
    "@babel/preset-typescript": "^7.23.0",
    "babel-loader": "^9.1.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0",
    "typescript": "^5.2.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.0.0",
    "eslint": "^8.50.0"
  },
  "jira": {
    "key": "com.apos.jira",
    "name": "APOS - Task→OKR Linker",
    "description": "Detect orphaned features, link tasks to OKRs, calculate trust score",
    "modules": {
      "jira:sidebar": "src/modules/sidebar.js",
      "jira:webhooks": "src/modules/webhooks.js",
      "jira:context-menu": "src/modules/contextMenu.js"
    }
  }
}
